# Splitflow Configuration Template
# Copy this file to '.env' and fill in the values securely

# MongoDB Configuration
MONGO_URL=mongodb://admin:YOUR_SECURE_PASSWORD_HERE@localhost:27017/splitflow?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Proxy Configuration (used for web scraping)
PROXY_URL=http://username:password@proxy_host:proxy_port/

# Buy Server URL
BUYSERVER_URL=http://localhost:1441/

# Discord Bot Integration
DISCORD_TOKEN=your_discord_bot_token_here
ANNOUNCEMENT_CHANNEL=your_discord_announcement_channel_id_here

# OpenAI/GPT Key
GPT_KEY=your_openai_api_key_here

# Sentry Error Reporting (Optional)
SENTRY_DSN=https://your_sentry_key@sentry_host/sentry_project_id
